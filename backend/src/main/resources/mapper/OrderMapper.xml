<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.arthaschan.metagptmall.mapper.OrderMapper">

  <resultMap id="OrderMap" type="com.arthaschan.metagptmall.entity.Order">
    <id property="id" column="id"/>
    <result property="orderNo" column="order_no"/>
    <result property="userId" column="user_id"/>
    <result property="status" column="status"/>
    <result property="totalCents" column="total_cents"/>
    <result property="currency" column="currency"/>
    <result property="createdAt" column="created_at"/>
  </resultMap>

  <insert id="insert" useGeneratedKeys="true" keyProperty="id">
    INSERT INTO orders (order_no, user_id, status, total_cents, currency)
    VALUES (#{orderNo}, #{userId}, #{status}, #{totalCents}, #{currency})
  </insert>

  <select id="findById" resultMap="OrderMap">
    SELECT id, order_no, user_id, status, total_cents, currency, created_at
    FROM orders
    WHERE id = #{id}
  </select>

</mapper>
